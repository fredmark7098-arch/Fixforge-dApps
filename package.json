{
  "name": "crypto_project",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "prebuild": "node scripts/ensure-build-diagnostics.js",
    "predev": "node scripts/ensure-build-diagnostics.js",
    "clean": "rm -rf .next out",
    "clean:deep": "rm -rf .next out .turbo node_modules/.cache",
    "dev": "npm run clean:deep && next dev",
    "dev:clean": "npm run clean && next dev",
    "dev:reset": "npm run clean:deep && next dev",
    "dev:turbo": "npm run clean && next dev --turbopack",
    "build": "next build",
    "start": "npx --yes serve@14 --listen 3000 out",
    "start:next": "next start",
    "lint": "next lint",
    "export": "next build",
    "deploy": "npm run export && touch out/.nojekyll"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@iconify/icons-ion": "^1.2.10",
    "@iconify/react": "^5.0.1",
    "aos": "^2.3.4",
    "axios": "^1.7.2",
    "date-fns": "^3.4.0",
    "gray-matter": "^4.0.3",
    "next": "15.3.9",
    "next-auth": "^4.24.7",
    "next-themes": "^0.4.6",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "react-hot-toast": "^2.4.1",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.7",
    "@types/aos": "^3.0.7",
    "@types/node": "^20",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "postcss": "^8",
    "tailwindcss": "^4.1.7",
    "typescript": "^5"
  }
}
